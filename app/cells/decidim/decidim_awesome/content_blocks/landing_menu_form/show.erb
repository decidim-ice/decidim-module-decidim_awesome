<% form.fields_for :settings, form.object.settings do |settings_fields| %>
  <%= settings_fields.hidden_field :menu_items, value: content_block.settings.menu_items %>

  <div class="row column">
    <%= render view: :table %>
  </div>

  <div class="row column">
    <%= settings_fields.check_box :sticky,
                                  label: t("sticky", scope: i18n_scope) %>
  </div>
  <div class="row column">
    <%= settings_fields.check_box :show_on_mobile,
                                  label: t("show_on_mobile", scope: i18n_scope) %>
  </div>
  <div class="row column">
    <%= settings_fields.select :alignment,
                               alignment_options,
                               label: t("alignment", scope: i18n_scope),
                               help_text: t("alignment_help", scope: i18n_scope) %>
  </div>

  <div class="row column mt-4">
    <p><%= t("css_help_html",
              scope: i18n_scope,
              link: link_to(t("css_help_link", scope: i18n_scope),
                            decidim_admin_decidim_awesome.config_path(:scoped_styles),
                            class: "text-secondary underline")).html_safe %></p>
    <code class="code-block mt-4">/* <%= t("css_comment_menu", scope: i18n_scope) %> */
.awesome-landing-menu {
  background: var(--primary);
}

/* <%= t("css_comment_link", scope: i18n_scope) %> */
.awesome-landing-menu .button__text {
  font-weight: bold;
}

/* <%= t("css_comment_hover", scope: i18n_scope) %> */
.awesome-landing-menu .button__text:hover {
  text-decoration: underline;
}</code>
  </div>
<% end %>

<%= decidim_drawer id: "landing-menu-item-drawer" do %>
  <div data-dialog-container class="layout-content"></div>
<% end %>
