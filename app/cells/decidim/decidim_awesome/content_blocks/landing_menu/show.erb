<nav id="<%= block_id %>"
     class="landing-menu hidden bg-white<%= " sticky top-0" if sticky? %>"
     aria-label="<%= t("name", scope: i18n_scope) %>">
  <div class="flex items-center gap-4 py-2 <%= justify_class %>">
    <% menu_items.each do |item| %>
      <a href="<%= item[:url] %>"
         class="landing-menu__link"
         <% if item[:target] == "_blank" %>
           target="_blank"
           rel="noopener noreferrer"
         <% end %>>
        <%= item[:label] %>
      </a>
    <% end %>
  </div>
</nav>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const nav = document.getElementById("<%= block_id %>");
    if (!nav) return;

    nav.querySelectorAll(".landing-menu__link").forEach(function(link) {
      const href = link.getAttribute("href");
      if (href && href.startsWith("#") && !document.querySelector(href)) {
        link.remove();
      }
    });

    nav.classList.remove("hidden");
  });
</script>
