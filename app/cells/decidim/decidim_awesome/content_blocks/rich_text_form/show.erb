<% form.fields_for :settings, form.object.settings do |settings_fields| %>
  <div class="row column">
    <%= settings_fields.text_field :block_id, label: t("block_id", scope: i18n_scope), placeholder: t("block_id_placeholder", scope: i18n_scope), help_text: t("block_id_help", scope: i18n_scope), value: default_block_id %>
  </div>

  <div class="row column">
    <%= settings_fields.translated :text_field, :title, label: t("title", scope: i18n_scope) %>
  </div>
<% end %>

<div class="awesome-rich-text-columns-wrapper" data-max-columns="<%= max_columns %>">
  <%# Template for createDynamicFields — cloned when "Add column" is clicked %>
  <% form.fields_for :settings, form.object.settings do |settings_fields| %>
    <% settings_fields.fields_for "columns[awesome-rich-text-column-id]", blank_column do |col_fields| %>
      <script type="text/template" class="decidim-template">
        <div class="awesome-rich-text-column card pt-4 mb-4 mx-4" id="awesome-rich-text-column-id-field">
          <div class="card-divider flex items-center justify-between">
            <h2 class="card-title"><span class="awesome-rich-text-column-title"><%= t("column_title", scope: i18n_scope) %></span></h2>
            <button type="button" class="button button__xs button__transparent-secondary small alert remove-awesome-rich-text-column button--title">
              <%= icon("delete-bin-line") %>
              <span class="hidden md:block"><%= t("remove_column", scope: i18n_scope) %></span>
            </button>
          </div>
          <div class="card-section">
            <%= column_fields(col_fields, blank_column, "awesome-rich-text-column-id") %>
            <% form.fields_for :images, content_block.images_container do |images_fields| %>
              <%= column_extra_fields(col_fields, "awesome-rich-text-column-id", images_fields, :background_image_0) %>
            <% end %>
          </div>
        </div>
      </script>
    <% end %>
  <% end %>

  <%# Existing columns %>
  <div class="awesome-rich-text-columns-list">
    <% column_objects.each_with_index do |col, idx| %>
      <div class="awesome-rich-text-column card pt-4 mb-4 mx-4" id="<%= idx %>-field">
        <div class="card-divider flex items-center justify-between">
          <h2 class="card-title"><span class="awesome-rich-text-column-title"><%= t("column_title", scope: i18n_scope) %></span></h2>
          <% if idx > 0 %>
            <button type="button" class="button button__xs button__transparent-secondary small alert remove-awesome-rich-text-column button--title">
              <%= icon("delete-bin-line") %>
              <span class="hidden md:block"><%= t("remove_column", scope: i18n_scope) %></span>
            </button>
          <% end %>
        </div>

        <div class="card-section">
          <% form.fields_for :settings, form.object.settings do |settings_fields| %>
            <% settings_fields.fields_for "columns[#{idx}]", col do |col_fields| %>
              <%= column_fields(col_fields, col, idx) %>
              <% form.fields_for :images, content_block.images_container do |images_fields| %>
                <%= column_extra_fields(col_fields, idx, images_fields, :"background_image_#{idx}") %>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="row column">
    <button type="button" class="button button__sm button__secondary add-awesome-rich-text-column mt-4">
      + <%= t("add_column", scope: i18n_scope) %>
    </button>
  </div>
</div>
