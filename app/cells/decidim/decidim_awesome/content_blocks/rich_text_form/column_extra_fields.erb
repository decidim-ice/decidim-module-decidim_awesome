<%# Background image %>
<div class="row column">
  <%= @images_fields.upload @image_field_name, label: t("background_image", scope: i18n_scope), help_text: t("background_image_help", scope: i18n_scope), button_class: "button button__sm button__transparent-secondary" %>
</div>
<div class="row column">
  <%= @col_fields.select :background_image_placement, placement_options, label: t("background_image_placement", scope: i18n_scope), help_text: t("background_image_placement_help", scope: i18n_scope) %>
</div>

<%# CSS customization hint %>
<% col_num = @column_id.is_a?(Integer) ? @column_id + 1 : "N" %>
<div class="row column mt-4">
  <% css_link = link_to(t("css_help_link", scope: i18n_scope),
                        decidim_admin_decidim_awesome.config_path(:scoped_styles),
                        class: "text-secondary underline") %>
  <p><%= t("css_help_html", scope: i18n_scope, link: css_link).html_safe %></p>
  <code class="code-block mt-4 text-xs">/* <%= t("css_comment_this_column", scope: i18n_scope, number: col_num) %> */
