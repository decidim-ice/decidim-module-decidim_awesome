<div class="item_show__header">
  <h2 class="item_show__header-title">
    <%= t(".title") %>
    <%= link_to t(".new"), decidim_admin_decidim_awesome.new_users_autoblock_path, class: "button button__sm button__secondary ml-auto" %>
  </h2>
</div>
<div class="card">
  <div class="card-section">
    <p class="help-text -mt-2 mb-4"><%= t(".description").html_safe %></p>

    <div class="table-scroll">
      <table class="table-list">
        <thead>
          <tr>
            <th><%= t(".headers.application_type") %></th>
            <th><%= t(".headers.type") %></th>
            <th><%= t(".headers.allowlist") %></th>
            <th><%= t(".headers.blocklist") %></th>
            <th><%= t(".headers.weight") %></th>
            <th><%= t(".headers.count") %></th>
            <th class="actions"></th>
          </tr>
        </thead>
        <tbody>
          <% current_rules.each do |item| %>
            <tr>
              <td><%= t(item["application_type"], scope: "decidim.decidim_awesome.admin.users_autoblocks.form.application_types") %></td>
              <td><%= t(item["type"], scope: "decidim.decidim_awesome.admin.users_autoblocks.form.types") %></td>
              <td><%= item["allowlist"] %></td>
              <td><%= item["blocklist"] %></td>
              <td><%= item["weight"] %></td>
              <td><%= @scores_counts[item["id"]] unless @scores_counts.nil? %></td>
              <td class="table-list__actions">
                <%= icon_link_to "pencil-line", decidim_admin_decidim_awesome.edit_users_autoblock_path(md5(item.to_json)), t(".edit"), class: "action-icon--edit" %>
                <%= icon_link_to "close-circle-line", decidim_admin_decidim_awesome.users_autoblock_path(md5(item.to_json)), t(".delete"), method: :delete, class: "action-icon--remove", data: { confirm: t(".confirm_destroy") } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="row mt-4 mb-4">
      <% if current_rules.any? %>
        <%= button_to t(".calculate_scores"), { action: "calculate_scores" }, form_class: "button button__secondary button__xs" %>
      <% end %>

      <% if @scores_counts.present? %>
        <%= link_to decidim_admin_decidim_awesome.download_report_users_autoblocks_path, class: "button button__secondary button__xs" do %>
          <%= t(".download_report_file") %>
          <%= icon "download-line", class: "dropdown-filter-icon" %>
        <% end %>
      <% end %>
    </div>

    <%= decidim_form_for(
      @config_form,
      method: :patch,
      url: update_config_users_autoblocks_path,
      html: { class: "form-defaults", id: "users_autoblocks_config" }
    ) do |f| %>
    <div class="card">
      <div class="card-section">
        <%= render partial: "config_form", locals: { form: f } %>
      </div>
    </div>
  <% end %>

    <div class="card">
      <%= button_to t(".detect_and_run"), { action: "detect_and_run" }, form_class: "button button__secondary button__xs", data: { "confirm" => t(".confirm_block") } %>
    </div>
  </div>
</div>
