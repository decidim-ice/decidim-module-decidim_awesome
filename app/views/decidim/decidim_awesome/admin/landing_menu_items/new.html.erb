<%= decidim_form_for(@form,
                    url: landing_menu_items_path(content_block_id: params[:content_block_id]),
                    method: :post,
                    remote: true,
                    html: { id: "landing-menu-item-form",
                            class: "form-defaults" }) do |f| %>
  <h1>
    <%= t(".title") %>
    <%= f.submit t(".save"), class: "button button__sm button__secondary" %>
  </h1>
  <%= render partial: "form", locals: { form: f, available_anchors: @available_anchors } %>
<% end %>
