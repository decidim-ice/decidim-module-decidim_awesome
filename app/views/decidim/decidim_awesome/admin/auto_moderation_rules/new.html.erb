<div class="item_show__header">
  <h2 class="item_show__header-title">
    Rule
      <%= link_to "Cancel", decidim_admin_decidim_awesome.auto_moderation_rules_path, class: "button button__sm button__secondary" %>
  </h2>
</div>

<div class="item__edit item__edit-1col">
  <div class="item__edit-form">
    <%= decidim_form_for(@form, url: decidim_admin_decidim_awesome.auto_moderation_rules_path, html: { class: "form-defaults form" }) do |f| %>
      <%= render partial: "form", object: f %>
      <div class="item__edit-sticky">
        <div class="item__edit-sticky-container">
          <%= f.submit "Save", class: "button button__sm button__secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
