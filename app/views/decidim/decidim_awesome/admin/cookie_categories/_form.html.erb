<div class="form__wrapper">
  <div class="card pt-4">
    <div class="card-section">
      <div class="row column">
        <%= form.text_field :slug, readonly: !@form.editable?, help_text: t(".slug_help") %>
      </div>
      <div class="row column">
        <%= form.check_box :mandatory %>
      </div>
      <div class="row column">
        <%= form.translated :text_field, :title, class: "h-12 w-full" %>
      </div>
      <div class="row column">
        <%= form.translated :text_area, :description, rows: 3, class: "w-full" %>
      </div>
      <div class="row column">
        <%= form.select :visibility, @form.visibility_options, {}, class: "mb-8", disabled: !@form.editable? %>
      </div>
    </div>
  </div>
</div>
