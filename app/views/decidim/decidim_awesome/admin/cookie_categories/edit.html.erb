<div class="item_show__header">
  <h2 class="item_show__header-title">
    <%= t ".title" %>
      <%= link_to t(".items"), decidim_admin_decidim_awesome.cookie_category_cookie_items_path(params[:slug]), class: "button button__sm button__transparent-secondary" %>
      <%= link_to t(".cancel"), decidim_admin_decidim_awesome.cookie_categories_path, class: "button button__sm button__secondary" %>
  </h2>
</div>

<div class="item__edit item__edit-1col">
  <div class="item__edit-form">
    <%= decidim_form_for(@form, url: cookie_category_path, method: :patch, html: { class: "form-defaults form edit_cookie_category" }) do |f| %>
      <%= render partial: "form", object: f, locals: { slug_editable: false } %>
      <div class="item__edit-sticky">
        <div class="item__edit-sticky-container">
          <%= f.submit t(".save"), class: "button button__sm button__secondary" %>
        </div>
      </div>
    <% end %>
    <%= render "decidim/decidim_awesome/admin/cookie_categories/script_config", category: params[:slug] %>
  </div>
</div>
